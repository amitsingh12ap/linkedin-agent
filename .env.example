# ─── Claude / Anthropic ───────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── LinkedIn ─────────────────────────────────────────────────────────────────
# Step-by-step setup in README.md → LinkedIn API Setup
LINKEDIN_ACCESS_TOKEN=your_linkedin_oauth_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:your_person_id_here

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Cron expression in UTC. Default = 03:30 UTC = 09:00 AM IST
CRON_SCHEDULE=30 3 * * *

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/agent.db

# ─── Dev / Testing ────────────────────────────────────────────────────────────
# Set to "true" to post immediately on startup (for testing)
IMMEDIATE_RUN=false
